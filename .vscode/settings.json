{
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file",
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "always",
    "source.format.oxc": "always"
  },
  // ZDOTDIR → .vscode/zdotdir/.zshrc: nvm + ~/.zshrc, then nvm use (.nvmrc) for sidebar npm scripts etc.
  "terminal.integrated.profiles.osx": {
    "zsh (workspace nvm)": {
      "path": "/bin/zsh",
      "args": ["-i"],
      "icon": "terminal",
      "env": {
        "ZDOTDIR": "${workspaceFolder}/.vscode/zdotdir"
      }
    }
  },
  "terminal.integrated.defaultProfile.osx": "zsh (workspace nvm)",
  "typescript.tsdk": "node_modules/typescript/lib",
  "css.lint.unknownAtRules": "ignore",
  "tailwindCSS.lint.suggestCanonicalClasses": "ignore",
  "oxc.fmt.configPath": ".oxfmtrc.json",
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "[typescript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[javascript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[html]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[css]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[scss]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[yaml]": {
    "editor.defaultFormatter": "joseph-ravenwolfe.kubernetes-yaml-formatter"
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "joseph-ravenwolfe.kubernetes-yaml-formatter"
  },
  "i18n-ally.localesPaths": ["src/core/i18n/locales"],
  "i18n-ally.namespace": true,
  "i18n-ally.pathMatcher": "{locale}/{namespaces}.json",
  "i18n-ally.sourceLanguage": "en",
  "i18n-ally.keystyle": "nested"
}
